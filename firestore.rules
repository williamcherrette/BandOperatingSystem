rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isSelf(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    function isBandMember(bandId) {
      return isSignedIn() &&
        exists(/databases/$(database)/documents/bands/$(bandId)/members/$(request.auth.uid));
    }

    // Single get() instead of exists() + get()
    function isBandAdmin(bandId) {
      return isSignedIn() &&
        get(/databases/$(database)/documents/bands/$(bandId)/members/$(request.auth.uid)).data.role == "admin";
    }

    // User profile document: users/{uid}
    match /users/{uid} {
      allow read, create, update, delete: if isSelf(uid);

      // User's band membership index: users/{uid}/bands/{bandId}
      match /bands/{bandId} {
        allow read, create, update, delete: if isSelf(uid);
      }
    }

    // Band root document: bands/{bandId}
    match /bands/{bandId} {
      // Signed-in users must be able to read band root docs to:
      // 1) validate join codes before membership exists
      // 2) check random code availability during band creation
      allow read: if isSignedIn() || isBandMember(bandId);

      // Allow any signed-in user to create a new band where they are owner.
      allow create: if isSignedIn() && request.resource.data.ownerId == request.auth.uid;

      // Band admins can maintain band metadata.
      allow update, delete: if isBandAdmin(bandId);

      // Band member documents: bands/{bandId}/members/{uid}
      match /members/{uid} {
        allow read: if isBandMember(bandId);

        // Combined: members can join as "member", band owner can self-assign "admin"
        allow create: if isSelf(uid) && (
          request.resource.data.role == "member" ||
          (request.resource.data.role == "admin" &&
            get(/databases/$(database)/documents/bands/$(bandId)).data.ownerId == request.auth.uid)
        );

        // Admins can update/remove members.
        allow update, delete: if isBandAdmin(bandId);
      }

      // Songs collection: bands/{bandId}/songs/{songId}
      match /songs/{songId} {
        allow read: if isBandMember(bandId);
        allow create, update: if isBandMember(bandId);
        allow delete: if isBandAdmin(bandId);
      }
    }

    // Deny everything else by default.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
